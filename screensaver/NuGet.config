<?xml version="1.0" encoding="utf-8"?>
<!-- Ensure the WebView2 package resolves from nuget.org even on machines whose
     global NuGet config only lists an offline/private source. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
